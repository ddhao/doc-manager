{
  "name": "doc-manager",
  "version": "1.0.0",
  "description": "办公室收文管理系统",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@hufe921/canvas-editor": "^0.9.132",
    "@tinymce/tinymce-react": "^6.3.0",
    "better-sqlite3": "^11.6.0",
    "docxtemplater": "^3.68.6",
    "pizzip": "^3.2.0",
    "tinymce": "^7.9.2"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.5.0",
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/pdfmake": "^0.2.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^5.22.0",
    "dayjs": "^1.11.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "pdfmake": "^0.2.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.docmanager.app",
    "productName": "办公室收文管理系统",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "asarUnpack": [
        "node_modules/better-sqlite3/**"
      ]
    }
  }
}
